# ============================================================
# Teka RDC — Environment Variables
# Copy to .env.development and fill in values
# ============================================================

# === General ===
NODE_ENV=development
APP_NAME=Teka RDC
DEFAULT_LOCALE=fr
SUPPORTED_LOCALES=fr,en
DEFAULT_CURRENCY=CDF
SUPPORTED_CURRENCIES=CDF,USD
DEFAULT_COUNTRY_CODE=+243

# === Database (Cloud PostgreSQL) ===
DATABASE_URL=postgresql://user:password@host:5432/teka_rdc?schema=public

# === Auth (JWT) ===
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
OTP_EXPIRY_MINUTES=5

# === Cloudinary (Media) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Resend (Email) ===
RESEND_API_KEY=
EMAIL_FROM=noreply@teka.cd

# === SMS Provider ===
# orange | africas_talking | mock
SMS_PROVIDER=orange

# === Orange DRC SMS ===
# https://developer.orange.com/apis/sms/getting-started
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_SENDER_ADDRESS=tel:+243XXXXXXXXX
ORANGE_API_BASE=https://api.orange.com

# === Africa's Talking (legacy fallback provider) ===
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=TekaRDC

# === Google OAuth ===
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# === Password hashing & resets ===
BCRYPT_ROUNDS=12
PASSWORD_RESET_EXPIRY_MINUTES=60
SELLER_SETUP_EXPIRY_HOURS=24

# === Payment (Flexpay Mobile Money) ===
FLEXPAY_API_URL=https://backend.flexpay.cd/api/rest/v1
FLEXPAY_API_KEY=
FLEXPAY_MERCHANT_ID=
FLEXPAY_CALLBACK_URL=http://localhost:5050/api/v1/payments/webhook/flexpay
FLEXPAY_WEBHOOK_SECRET=
PAYMENT_MOCK_MODE=true

# === Service URLs ===
API_URL=http://localhost:5050
API_PORT=5050
BUYER_WEB_URL=http://localhost:5000
BUYER_WEB_PORT=5000
SELLER_WEB_URL=http://localhost:5100
SELLER_WEB_PORT=5100
ADMIN_WEB_URL=http://localhost:5200
ADMIN_WEB_PORT=5200

# === CORS ===
CORS_ORIGINS=http://localhost:5000,http://localhost:5100,http://localhost:5200,http://localhost:8080
