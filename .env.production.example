# ============================================================
# Teka RDC — Production Environment Variables
# Copy to .env.production and fill in all values
# ============================================================

# === General ===
NODE_ENV=production
APP_NAME=Teka RDC
DEFAULT_LOCALE=fr
SUPPORTED_LOCALES=fr,en
DEFAULT_CURRENCY=CDF
SUPPORTED_CURRENCIES=CDF,USD
DEFAULT_COUNTRY_CODE=+243

# === Database (Cloud PostgreSQL — Neon/Supabase/Railway) ===
# Use connection pooling with appropriate limits for production
DATABASE_URL=postgresql://user:password@host:5432/teka_rdc?schema=public&connection_limit=20&pool_timeout=30

# === Redis (Docker service) ===
REDIS_HOST=redis
REDIS_PORT=6379
# REQUIRED: Set a strong password for production Redis
REDIS_PASSWORD=

# === Auth (JWT) ===
# REQUIRED: Generate strong random strings (min 64 chars recommended)
# Example: openssl rand -base64 64
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
OTP_EXPIRY_MINUTES=5

# === Cloudinary (Media Storage & CDN) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Resend (Transactional Email) ===
RESEND_API_KEY=
EMAIL_FROM=noreply@teka.cd

# === Africa's Talking (SMS & OTP) ===
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=TekaRDC

# === Payment (Flexpay Mobile Money) ===
FLEXPAY_API_URL=https://backend.flexpay.cd/api/rest/v1
FLEXPAY_API_KEY=
FLEXPAY_MERCHANT_ID=
FLEXPAY_CALLBACK_URL=https://teka.cd/api/v1/payments/webhook/flexpay
FLEXPAY_WEBHOOK_SECRET=
# IMPORTANT: Set to false for real payments in production
PAYMENT_MOCK_MODE=false

# === Service URLs (Production) ===
API_URL=https://teka.cd/api
API_PORT=5050
BUYER_WEB_URL=https://teka.cd
BUYER_WEB_PORT=5000
SELLER_WEB_URL=https://teka.cd/seller
SELLER_WEB_PORT=5100
ADMIN_WEB_URL=https://teka.cd/admin
ADMIN_WEB_PORT=5200

# === CORS ===
CORS_ORIGINS=https://teka.cd,https://www.teka.cd
